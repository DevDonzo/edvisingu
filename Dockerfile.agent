# One image for the entire 25-agent fleet. docker-compose runs 25 containers
# from this single build, each with its own AGENT_NAME + port.
FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY core ./core
COPY tools ./tools
COPY souls ./souls
COPY agent.py .

EXPOSE 8000

# AGENT_NAME is provided per-service by docker-compose (defaults to hermes-core).
CMD ["uvicorn", "agent:app", "--host", "0.0.0.0", "--port", "8000"]
